#!/bin/bash
# .githooks/pre-commit
#
# Pre-commit hook to prevent accidental secret commits
# Install with: git config core.hooksPath .githooks

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "🔒 Running pre-commit security check..."

# Files to check (staged files only)
FILES=$(git diff --cached --name-only --diff-filter=ACM)

FOUND_SECRETS=0

# Check for specific sensitive files that should never be committed
SENSITIVE_FILES=(
    "config.yaml"
    ".env"
    "secrets.yaml"
)

for sensitive_file in "${SENSITIVE_FILES[@]}"; do
    for file in $FILES; do
        if [[ "$(basename "$file")" == "$sensitive_file" ]]; then
            echo -e "${RED}⚠️  Sensitive file staged: $file${NC}"
            FOUND_SECRETS=1
        fi
    done
done

# Check for common secret patterns in staged files
SECRET_PATTERNS=(
    "password\s*=\s*['\"][^'\"]+['\"]"
    "api_key\s*=\s*['\"][^'\"]+['\"]"
    "token\s*=\s*['\"][^'\"]+['\"]"
    "secret\s*=\s*['\"][^'\"]+['\"]"
    "MQTT_PASSWORD\s*=\s*['\"][^'\"]+['\"]"
)

for file in $FILES; do
    # Skip example files and documentation
    if [[ "$file" == *".example."* ]] || [[ "$file" == *"docs/"* ]] || [[ "$file" == *"README"* ]]; then
        continue
    fi
    
    # Skip binary files
    if file "$file" | grep -q "binary"; then
        continue
    fi
    
    # Check for secret patterns
    for pattern in "${SECRET_PATTERNS[@]}"; do
        if grep -iE "$pattern" "$file" | grep -v "None" | grep -v "null" | grep -v "your_" | grep -v "example" >/dev/null 2>&1; then
            echo -e "${YELLOW}⚠️  Potential secret found in: $file${NC}"
            grep -iE "$pattern" "$file" | head -3
            FOUND_SECRETS=1
        fi
    done
done

# Check if config.yaml is in .gitignore
if [ ! -f ".gitignore" ] || ! grep -q "^config.yaml$" .gitignore; then
    echo -e "${YELLOW}⚠️  config.yaml not in .gitignore!${NC}"
    FOUND_SECRETS=1
fi

if [ $FOUND_SECRETS -eq 1 ]; then
    echo ""
    echo -e "${RED}❌ Commit blocked - sensitive data detected!${NC}"
    echo ""
    echo "These files contain secrets and should not be committed:"
    echo "  - config.yaml (contains MQTT credentials, device IPs)"
    echo "  - .env (contains tokens/secrets)"
    echo ""
    echo "Use config.example.yaml as a template instead."
    echo ""
    echo "To bypass this check (if you know what you're doing):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

echo -e "${GREEN}✅ No secrets detected - commit allowed${NC}"
exit 0
